SUBTAGGER_CONFIG=/config/config.yml
SUBTAGGER_LOG_LEVEL=INFO
SUBTAGGER_DRY_RUN=false
SUBTAGGER_MIN_CONFIDENCE=0.85
SUBTAGGER_USE_WHISPER=false
SUBTAGGER_USE_OLLAMA=false
SUBTAGGER_OLLAMA_URL=http://ollama:11434
SUBTAGGER_OLLAMA_MODEL=llama3
SUBTAGGER_WHISPER_MODEL=base
SUBTAGGER_AUDIT_LOG=/logs/subtagger_audit.db
SUBTAGGER_WATCH_MODE=false
SUBTAGGER_WATCH_INTERVAL=3600
